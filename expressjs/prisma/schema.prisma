generator client {
  provider     = "prisma-client-js"
  output       = "../src/common/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Roles {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  level           Int
  description     String?
  RolePermissions RolePermissions[]
  UserRoles       UserRoles[]
}

model Permissions {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  description     String?
  RolePermissions RolePermissions[]
}

model RolePermissions {
  roleId       Int
  permissionId Int
  permission   Permissions @relation(fields: [permissionId], references: [id])
  role         Roles       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId], map: "RolePermissions_permissionId_fkey")
}

model UserRoles {
  userId Int
  roleId Int
  role   Roles @relation(fields: [roleId], references: [id])
  user   Users @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@index([roleId], map: "UserRoles_roleId_fkey")
}

model Departments {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  managerId Int?
  createdAt DateTime @default(now())
  manager   Users?   @relation("DeptManager", fields: [managerId], references: [id])
  users     Users[]

  @@index([managerId])
}

model Users {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  password           String?
  fullName           String
  avatar             String?
  departmentId       Int?
  leaderId           Int?
  joinDate           DateTime?
  status             EmployeeStatus     @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  isDeleted          Boolean            @default(false)
  approvals          Approvals[]
  articles           Articles[]
  attendances        Attendances[]
  chatMemberships    ChatGroupMembers[]
  ownedChatGroups    ChatGroups[]
  sentMessages       ChatMessages[]
  managedDepartments Departments[]      @relation("DeptManager")
  leaveBalances      LeaveBalances[]
  leaveRequests      LeaveRequests[]
  notifications      Notifications[]
  overtimeRequests   OvertimeRequests[]
  payrolls           Payrolls[]
  roles              UserRoles[]
  department         Departments?       @relation(fields: [departmentId], references: [id])
  leader             Users?             @relation("LeaderSub", fields: [leaderId], references: [id])
  subordinates       Users[]            @relation("LeaderSub")

  @@index([departmentId])
  @@index([leaderId])
}

model Attendances {
  id           Int       @id @default(autoincrement())
  userId       Int
  date         DateTime  @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Float?
  lateMinutes  Int       @default(0)
  user         Users     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model LeaveBalances {
  id         Int   @id @default(autoincrement())
  userId     Int
  year       Int
  totalDays  Float
  usedDays   Float @default(0)
  remainDays Float
  user       Users @relation(fields: [userId], references: [id])

  @@unique([userId, year])
}

model LeaveRequests {
  id        Int           @id @default(autoincrement())
  userId    Int
  type      LeaveType
  startDate DateTime      @db.Date
  endDate   DateTime      @db.Date
  totalDays Float
  reason    String?
  status    RequestStatus @default(PENDING_LEADER)
  createdAt DateTime      @default(now())
  user      Users         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model OvertimeRequests {
  id        Int           @id @default(autoincrement())
  userId    Int
  date      DateTime      @db.Date
  startTime DateTime
  endTime   DateTime
  hours     Float
  reason    String?
  status    RequestStatus @default(PENDING_LEADER)
  createdAt DateTime      @default(now())
  user      Users         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Approvals {
  id          Int            @id @default(autoincrement())
  requestType RequestType
  requestId   Int
  approverId  Int
  roleLevel   Int
  stepOrder   Int
  status      ApprovalStatus @default(PENDING)
  comment     String?
  approvedAt  DateTime?
  createdAt   DateTime       @default(now())
  approver    Users          @relation(fields: [approverId], references: [id])

  @@index([requestType, requestId])
  @@index([approverId], map: "Approvals_approverId_fkey")
}

model Payrolls {
  id          Int   @id @default(autoincrement())
  userId      Int
  month       Int
  year        Int
  baseSalary  Float
  overtimePay Float
  deduction   Float
  bonus       Float
  netSalary   Float
  user        Users @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}

model Notifications {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      Users    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Articles {
  id        Int       @id @default(autoincrement())
  title     String?
  content   String?
  imageUrl  String?
  views     Int       @default(0)
  userId    Int?
  deletedBy Int       @default(0)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  user      Users?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ChatGroups {
  id               Int                @id @default(autoincrement())
  name             String?            @db.VarChar(255)
  ownerId          Int?
  deletedBy        Int                @default(0)
  isDeleted        Boolean            @default(false)
  deletedAt        DateTime?          @db.Timestamp(0)
  createdAt        DateTime           @default(now()) @db.Timestamp(0)
  updatedAt        DateTime           @default(now()) @db.Timestamp(0)
  ChatGroupMembers ChatGroupMembers[]
  Users            Users?             @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatGroups_ibfk_1")
  ChatMessages     ChatMessages[]

  @@index([ownerId], map: "ownerId")
}

model ChatGroupMembers {
  id          Int         @id @default(autoincrement())
  userId      Int?
  chatGroupId Int?
  deletedBy   Int         @default(0)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?   @db.Timestamp(0)
  createdAt   DateTime    @default(now()) @db.Timestamp(0)
  updatedAt   DateTime    @default(now()) @db.Timestamp(0)
  Users       Users?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatGroupMembers_ibfk_1")
  ChatGroups  ChatGroups? @relation(fields: [chatGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatGroupMembers_ibfk_2")

  @@index([chatGroupId], map: "chatGroupId")
  @@index([userId], map: "userId")
}

model ChatMessages {
  id           Int         @id @default(autoincrement())
  chatGroupId  Int?
  userIdSender Int?
  messageText  String?     @db.Text
  deletedBy    Int         @default(0)
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?   @db.Timestamp(0)
  createdAt    DateTime    @default(now()) @db.Timestamp(0)
  updatedAt    DateTime    @default(now()) @db.Timestamp(0)
  ChatGroups   ChatGroups? @relation(fields: [chatGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatMessages_ibfk_1")
  Users        Users?      @relation(fields: [userIdSender], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatMessages_ibfk_2")

  @@index([chatGroupId], map: "chatGroupId")
  @@index([userIdSender], map: "userIdSender")
}
enum EmployeeStatus {
  ACTIVE
  PROBATION
  RESIGNED
  TERMINATED
}

enum RequestStatus {
  PENDING_LEADER
  PENDING_MANAGER
  PENDING_DIRECTOR
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  LEAVE
  OVERTIME
}
