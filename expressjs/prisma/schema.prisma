generator client {
  provider     = "prisma-client-js"
  output       = "../src/common/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Articles {
  id        Int       @id @default(autoincrement())
  title     String?   @db.VarChar(255)
  content   String?   @db.Text
  imageUrl  String?   @db.VarChar(255)
  views     Int       @default(0)
  userId    Int?
  deletedBy Int       @default(0)
  isDeleted Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(0)
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @default(now()) @db.Timestamp(0)
  Users     Users?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Articles_ibfk_1")

  @@index([userId], map: "userId")
}

model Articles_demo {
  id        Int       @id @default(autoincrement())
  title     String?   @db.VarChar(255)
  content   String?   @db.Text
  imageUrl  String?   @db.VarChar(255)
  views     Int?      @default(0)
  userId    Int
  deletedBy Int?      @default(0)
  isDeleted Boolean?  @default(false)
  deletedAt DateTime? @db.Timestamp(0)
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @default(now()) @db.Timestamp(0)
  Users     Users     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Articles_demo_ibfk_1")

  @@index([userId], map: "userId")
}

model Foods {
  id          Int       @id @default(autoincrement())
  name        String?   @db.VarChar(255)
  description String?   @default("Chưa có thông tin") @db.VarChar(255)
  deletedBy   Int       @default(0)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime? @db.Timestamp(0)
  createdAt   DateTime  @default(now()) @db.Timestamp(0)
  updatedAt   DateTime  @default(now()) @db.Timestamp(0)
  Orders      Orders[]
}

model Orders {
  id     Int    @id @default(autoincrement())
  userId Int?
  foodId Int?
  Users  Users? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Orders_ibfk_1")
  Foods  Foods? @relation(fields: [foodId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Orders_ibfk_2")

  @@index([foodId], map: "foodId")
  @@index([userId], map: "userId")
}

model Users {
  id               Int                @id @default(autoincrement())
  email            String             @unique(map: "email") @db.VarChar(255)
  fullName         String?            @db.VarChar(255)
  avatar           String?            @db.Text
  age              Int?
  totpSecret       String?            @db.VarChar(255)
  googleId         String?            @db.VarChar(255)
  deletedBy        Int                @default(0)
  isDeleted        Boolean            @default(false)
  deletedAt        DateTime?          @db.Timestamp(0)
  createdAt        DateTime           @default(now()) @db.Timestamp(0)
  updatedAt        DateTime           @default(now()) @db.Timestamp(0)
  password         String?            @db.VarChar(255)
  Articles         Articles[]
  Articles_demo    Articles_demo[]
  ChatGroupMembers ChatGroupMembers[]
  ChatGroups       ChatGroups[]
  ChatMessages     ChatMessages[]
  Orders           Orders[]
}

model Departments {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  managerId Int?
  createdAt DateTime    @default(now())
  manager   Employees?  @relation("DeptManager", fields: [managerId], references: [id])
  Employees Employees[]

  @@index([managerId], map: "Departments_managerId_fkey")
}

model Roles {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  level     Int
  Employees Employees[]
}

model Employees {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  fullName           String
  password           String?
  avatar             String?
  departmentId       Int?
  roleId             Int?
  joinDate           DateTime?
  status             EmployeeStatus     @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  Approvals          Approvals[]
  Attendances        Attendances[]
  managedDepartments Departments[]      @relation("DeptManager")
  Departments        Departments?       @relation(fields: [departmentId], references: [id])
  Roles              Roles?             @relation(fields: [roleId], references: [id])
  LeaveBalances      LeaveBalances[]
  LeaveRequests      LeaveRequests[]
  Notifications      Notifications[]
  OvertimeRequests   OvertimeRequests[]
  Payrolls           Payrolls[]

  @@index([departmentId], map: "Employees_departmentId_fkey")
  @@index([roleId], map: "Employees_roleId_fkey")
}

model Attendances {
  id           Int       @id @default(autoincrement())
  employeeId   Int
  date         DateTime  @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Float?
  lateMinutes  Int       @default(0)
  Employees    Employees @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model LeaveBalances {
  id         Int       @id @default(autoincrement())
  employeeId Int
  year       Int
  totalDays  Float
  usedDays   Float     @default(0)
  remainDays Float
  Employees  Employees @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
}

model LeaveRequests {
  id         Int           @id @default(autoincrement())
  employeeId Int
  type       LeaveType
  startDate  DateTime      @db.Date
  endDate    DateTime      @db.Date
  totalDays  Float
  reason     String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  Employees  Employees     @relation(fields: [employeeId], references: [id])

  @@index([employeeId], map: "LeaveRequests_employeeId_fkey")
}

model OvertimeRequests {
  id         Int           @id @default(autoincrement())
  employeeId Int
  date       DateTime      @db.Date
  startTime  DateTime
  endTime    DateTime
  hours      Float
  reason     String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  Employees  Employees     @relation(fields: [employeeId], references: [id])

  @@index([employeeId], map: "OvertimeRequests_employeeId_fkey")
}

model Approvals {
  id          Int            @id @default(autoincrement())
  requestType RequestType
  requestId   Int
  approverId  Int
  level       Int
  status      ApprovalStatus @default(PENDING)
  comment     String?
  approvedAt  DateTime?
  createdAt   DateTime       @default(now())
  Employees   Employees      @relation(fields: [approverId], references: [id])

  @@index([requestType, requestId])
  @@index([approverId], map: "Approvals_approverId_fkey")
}

model Payrolls {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  month       Int
  year        Int
  baseSalary  Float
  overtimePay Float
  deduction   Float
  bonus       Float
  netSalary   Float
  Employees   Employees @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model Notifications {
  id         Int       @id @default(autoincrement())
  employeeId Int
  title      String
  content    String
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  Employees  Employees @relation(fields: [employeeId], references: [id])

  @@index([employeeId], map: "Notifications_employeeId_fkey")
}

model ChatGroupMembers {
  id          Int         @id @default(autoincrement())
  userId      Int?
  chatGroupId Int?
  deletedBy   Int         @default(0)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?   @db.Timestamp(0)
  createdAt   DateTime    @default(now()) @db.Timestamp(0)
  updatedAt   DateTime    @default(now()) @db.Timestamp(0)
  Users       Users?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatGroupMembers_ibfk_1")
  ChatGroups  ChatGroups? @relation(fields: [chatGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatGroupMembers_ibfk_2")

  @@index([chatGroupId], map: "chatGroupId")
  @@index([userId], map: "userId")
}

model ChatGroups {
  id               Int                @id @default(autoincrement())
  name             String?            @db.VarChar(255)
  ownerId          Int?
  deletedBy        Int                @default(0)
  isDeleted        Boolean            @default(false)
  deletedAt        DateTime?          @db.Timestamp(0)
  createdAt        DateTime           @default(now()) @db.Timestamp(0)
  updatedAt        DateTime           @default(now()) @db.Timestamp(0)
  ChatGroupMembers ChatGroupMembers[]
  Users            Users?             @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatGroups_ibfk_1")
  ChatMessages     ChatMessages[]

  @@index([ownerId], map: "ownerId")
}

model ChatMessages {
  id           Int         @id @default(autoincrement())
  chatGroupId  Int?
  userIdSender Int?
  messageText  String?     @db.Text
  deletedBy    Int         @default(0)
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?   @db.Timestamp(0)
  createdAt    DateTime    @default(now()) @db.Timestamp(0)
  updatedAt    DateTime    @default(now()) @db.Timestamp(0)
  ChatGroups   ChatGroups? @relation(fields: [chatGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatMessages_ibfk_1")
  Users        Users?      @relation(fields: [userIdSender], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ChatMessages_ibfk_2")

  @@index([chatGroupId], map: "chatGroupId")
  @@index([userIdSender], map: "userIdSender")
}

enum EmployeeStatus {
  ACTIVE
  PROBATION
  RESIGNED
  TERMINATED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  LEAVE
  OVERTIME
}
